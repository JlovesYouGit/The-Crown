# AMD Quantum Mesh Rendering Boost DLL CMakeLists.txt
# Provides optimized mesh rendering capabilities using quantum computing

cmake_minimum_required(VERSION 3.10)

# Project information
project(QuantumMeshBoostDLL VERSION 1.0.0 DESCRIPTION "AMD Quantum Mesh Rendering Boost DLL")

# Set C++ standard
set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

# Set the library name
set(LIBRARY_NAME QuantumMeshBoost)

# Add the library as a shared library (DLL on Windows)
add_library(${LIBRARY_NAME} SHARED
    QuantumMeshBoost.cpp
    QuantumMeshBoost.h
)

# Set preprocessor definitions for Windows DLL export
if(WIN32)
    target_compile_definitions(${LIBRARY_NAME} PRIVATE QUANTUM_MESH_BOOST_EXPORTS)
endif()

# Set target properties
set_target_properties(${LIBRARY_NAME} PROPERTIES
    VERSION ${PROJECT_VERSION}
    SOVERSION 1
    PUBLIC_HEADER QuantumMeshBoost.h
)

# Copy GGML DLLs to output directory
if(WIN32)
    add_custom_command(TARGET ${LIBRARY_NAME} POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E copy
            ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/build-vs/bin/Release/ggml-base.dll
            $<TARGET_FILE_DIR:${LIBRARY_NAME}>
        COMMAND ${CMAKE_COMMAND} -E copy
            ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/build-vs/bin/Release/ggml-cpu.dll
            $<TARGET_FILE_DIR:${LIBRARY_NAME}>
        COMMAND ${CMAKE_COMMAND} -E copy
            ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/build-vs/bin/Release/ggml.dll
            $<TARGET_FILE_DIR:${LIBRARY_NAME}>
    )
endif()

# Copy model to output directory
if(WIN32)
    add_custom_command(TARGET ${LIBRARY_NAME} POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E copy
            ${CMAKE_CURRENT_SOURCE_DIR}/../Models/quantum_render_optimization.gguf
            $<TARGET_FILE_DIR:${LIBRARY_NAME}>
    )
endif()

# Include directories
target_include_directories(${LIBRARY_NAME} PUBLIC
    ${CMAKE_CURRENT_SOURCE_DIR}
)

# Link libraries (if needed)
target_link_libraries(${LIBRARY_NAME} PRIVATE
    ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/build-vs/src/Release/ggml.lib
    ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/build-vs/src/Release/ggml-base.lib
    ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/build-vs/src/Release/ggml-cpu.lib
)

# Include directories for GGML
target_include_directories(${LIBRARY_NAME} PRIVATE
    ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/include
)

# Installation rules
install(TARGETS ${LIBRARY_NAME}
    LIBRARY DESTINATION lib
    PUBLIC_HEADER DESTINATION include
)

# Create a .def file for Windows DLL exports (optional)
if(WIN32)
    configure_file(
        "${CMAKE_CURRENT_SOURCE_DIR}/QuantumMeshBoost.def.in"
        "${CMAKE_CURRENT_BINARY_DIR}/QuantumMeshBoost.def"
    )
    target_sources(${LIBRARY_NAME} PRIVATE "${CMAKE_CURRENT_BINARY_DIR}/QuantumMeshBoost.def")
endif()

# Add subdirectory for sample applications
add_subdirectory(. ${CMAKE_BINARY_DIR}/Apps)